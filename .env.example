# =============================================================================
# .env.example
# Copy this file to .env on the production server and fill in the values.
# .env is gitignored and must NEVER be committed to the repository.
# =============================================================================

# Host port the Next.js Docker container is bound to.
# The host nginx proxies portal.vems.co.ke → localhost:APP_PORT
# Change this if 3010 is already taken by another container.
APP_PORT=3010

# Optional: override the API base URL at build time (NEXT_PUBLIC_ vars are
# baked into the client bundle during `next build`)
# NEXT_PUBLIC_API_URL=https://api.vems.co.ke/api/v1

# Email used for Let's Encrypt registration / expiry notifications
LETSENCRYPT_EMAIL=admin@vems.co.ke
